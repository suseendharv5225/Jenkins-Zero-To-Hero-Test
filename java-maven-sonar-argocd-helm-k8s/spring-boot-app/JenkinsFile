pipeline {
  agent any

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Run Inside Docker') {
      steps {
        script {
          docker.image('suseendhar/pipelinehelp2').inside('--user root -v /var/run/docker.sock:/var/run/docker.sock') {

            sh '''
              # Fresh clone (IMPORTANT FIX)
              rm -rf repo
              git clone https://github.com/suseendharv5225/Jenkins-Zero-To-Hero.git repo
            '''

            // Build
            sh '''
              cd repo/java-maven-sonar-argocd-helm-k8s/spring-boot-app
              mvn clean package -DskipTests
            '''

            // Sonar
            withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
              sh '''
                cd repo/java-maven-sonar-argocd-helm-k8s/spring-boot-app
                mvn sonar:sonar \
                  -Dsonar.login=$SONAR_AUTH_TOKEN \
                  -Dsonar.host.url=http://54.175.234.168:9000
              '''
            }

            // Docker
            sh '''
              cd repo/java-maven-sonar-argocd-helm-k8s/spring-boot-app
              docker build -t suseendhar/mypipeline:${BUILD_NUMBER} .
            '''

            docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
              sh 'docker push suseendhar/mypipeline:${BUILD_NUMBER}'
            }

            // Git update (NOW WORKS)
            withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
              sh '''
                cd repo

                git config user.email "suseendharv5225@gmail.com"
                git config user.name "suseendharv5225"

                sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

                git add .
                git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes"

                git push https://${GITHUB_TOKEN}@github.com/suseendharv5225/Jenkins-Zero-To-Hero HEAD:main
              '''
            }

          }
        }
      }
    }
  }
}
